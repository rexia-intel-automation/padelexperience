{% extends "layouts/admin.njk" %}
{% block content %}

<div class="admin-topbar">
  <div>
    <h1>{{ 'Editar imagem' if item else 'Nova imagem' }}</h1>
    <p>Imagens exibidas na seção "Experiência" do site.</p>
  </div>
  <a class="btn btn-ghost btn-sm" href="/admin/galeria">Voltar</a>
</div>

{% if error %}<div class="alert alert-danger">{{ error }}</div>{% endif %}

<form class="form-grid card" method="post" enctype="multipart/form-data"
      action="{{ '/admin/galeria/' + item.id if item else '/admin/galeria' }}">
  <input type="hidden" name="csrf" value="{{ csrfToken }}">
  <div class="field">
    <label for="image">Imagem</label>
    {% if item %}<img class="form-thumb" src="{{ item.image }}" alt="Imagem atual">{% endif %}
    <input class="input" type="file" id="image" name="image" accept="image/*">
    <small>Uploads são convertidos automaticamente para webp.</small>
  </div>
  <div class="field">
    <label for="image_url">Imagem por link (URL)</label>
    <input class="input" type="url" id="image_url" name="image_url" value="{{ item.image if item and item.image and item.image.startsWith('http') }}" placeholder="https://...">
    <small>Alternativa ao upload: link direto para a imagem. Se um arquivo for enviado acima, ele tem prioridade.</small>
  </div>
  <div class="field">
    <label for="caption">Legenda</label>
    <input class="input" type="text" id="caption" name="caption" value="{{ item.caption if item }}">
  </div>
  <div class="field">
    <label for="sort">Ordem</label>
    <input class="input" type="number" id="sort" name="sort" value="{{ item.sort if item else 0 }}">
    <small>A imagem de ordem mais baixa também aparece no painel do hero.</small>
  </div>
  <div class="form-actions">
    <button class="btn btn-primary" type="submit">Salvar</button>
    <a class="btn btn-ghost" href="/admin/galeria">Cancelar</a>
  </div>
</form>

{% endblock %}
